{
  "name": "OpenAPI Mini Viewer",
  "id": "openapi-mini-viewer-local",
  "api": "1.0.0",
  "editorType": ["figma"],
  "main": "dist/main.js",
  "ui": "dist/index.html",
  "documentAccess": "dynamic-page",
  "relaunchButtons": [
    {
      "command": "refresh",
      "name": "Refresh OpenAPI card"
    }
  ],
  "networkAccess": {
    "allowedDomains": ["*"],
    "reasoning": "The plugin fetches user-provided public Swagger/OpenAPI JSON URLs so designers can render endpoint documentation from any API specification.",
    "devAllowedDomains": []
  }
}
