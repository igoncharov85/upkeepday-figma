{
  "name": "openapi-mini-viewer-figma-widget",
  "version": "1.0.0",
  "description": "A Figma widget that renders compact Swagger/OpenAPI endpoint cards.",
  "scripts": {
    "build": "npm run build:ui && npm run build:widget",
    "build:ui": "vite build --config vite.ui.config.ts",
    "build:widget": "esbuild src/widget.tsx --bundle --outfile=dist/widget.js --target=es2017 --format=iife --jsx-factory=figma.widget.h --jsx-fragment=figma.widget.Fragment --loader:.png=dataurl --loader:.svg=dataurl",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@figma/widget-typings": "*",
    "@types/node": "^22.15.21",
    "esbuild": "*",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
